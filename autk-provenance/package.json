{
  "name": "autk-provenance",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/autk-provenance.umd.cjs",
  "module": "./dist/autk-provenance.js",
  "types": "./dist/index.d.ts",
