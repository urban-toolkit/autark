{
  "name": "autk-compute",
  "version": "1.3.0",
  "keywords": ["urban", "data management", "WebGPU"],
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/autk-compute.umd.cjs",
  "module": "./dist/autk-compute.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/autk-compute.js",
      "require": "./dist/autk-compute.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev-build": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "doc": "typedoc --options typedoc.json"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/rbush": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-theme-oxide": "^0.2.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4"
  }
}
