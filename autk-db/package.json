{
  "name": "autk-db",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/autk-db.umd.cjs",
  "module": "./dist/autk-db.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/autk-db.js",
      "require": "./dist/autk-db.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev-build": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "doc": "typedoc --options typedoc.json --watch"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/rbush": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typedoc": "^0.28.14",
    "typedoc-theme-oxide": "^0.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.30.0",
    "@turf/turf": "^7.2.0",
    "apache-arrow": "^21.1.0",
    "rbush": "^4.0.1"
  }
}