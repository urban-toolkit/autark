{
    "source": {
        "include": [
            "src"
        ],
        "includePattern": "\\.(ts)$",
        "excludePattern": "(node_modules/|docs)"
    },
    "plugins": [
        "node_modules/better-docs/typescript"
    ],
    "opts": {
        "encoding": "utf8",
        "destination": "./docs",
        "readme": "../readme.md",
        "recurse": true,
        "verbose": true,
        "template": "node_modules/better-docs"
    },
    "templates": {
        "cleverLinks": true,
        "monospaceLinks": true,
        "search": true
    },
    "better-docs": {
        "name": "Autark Map Documentation",
        "logo": "../logo.png",
        "title": "Autark Map",
        "hideGenerator": false,
        "navLinks": [
            {
                "label": "Github",
                "href": "https://github.com/urban-toolkit/autark"
            }
        ]
    }
}