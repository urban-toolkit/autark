            "params": [
              {
                "name": "data",
                "value": "\n      [out:json][timeout:180][maxsize:536870912];\n\n      area[\"name\"=\"New York\"]->.areaMain;\n      area[\"name\"=\"Battery Park City\"](area.areaMain)->.area1;\n      relation[\"name\"=\"Battery Park City\"](area.areaMain)->.rel1;\n      (\n        way[\"leisure\"](area.area1);\n        way[\"landuse\"](area.area1);\n        way[\"water\"](area.area1);\n        way[\"highway\"](area.area1);\n        way[\"natural\"~\"^(wood|grass|water|wetland|bay|strait|spring)$\"](area.area1);\n      )->.dataWays1;\n      way(r.rel1)->.boundaryWays1;\n      area[\"name\"=\"Financial District\"](area.areaMain)->.area2;\n      relation[\"name\"=\"Financial District\"](area.areaMain)->.rel2;\n      (\n        way[\"leisure\"](area.area2);\n        way[\"landuse\"](area.area2);\n        way[\"water\"](area.area2);\n        way[\"highway\"](area.area2);\n        way[\"natural\"~\"^(wood|grass|water|wetland|bay|strait|spring)$\"](area.area2);\n      )->.dataWays2;\n      way(r.rel2)->.boundaryWays2;\n\n      ( .rel1; .rel2; );\n      out body;\n\n      ( .dataWays1; .boundaryWays1; .dataWays2; .boundaryWays2; );\n      out geom qt;\n    "
              }
            ],
            "_file": "bd844c5f9efd1e831ba17568016c7ca882288647.dat"
          }
