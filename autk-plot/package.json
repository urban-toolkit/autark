{
  "name": "autk-plot",
  "version": "1.3.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/autk-plot.umd.cjs",
  "module": "./dist/autk-plot.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/autk-plot.js",
      "require": "./dist/autk-plot.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev-build": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "doc": "typedoc --options typedoc.json",
    "doc:watch": "typedoc --options typedoc.json --watch"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.7",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-theme-oxide": "^0.2.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "autk-types": "*",
    "@turf/turf": "^7.3.4",
    "d3": "^7.9.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2"
  }
}
